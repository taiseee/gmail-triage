# Gmail アカウント一覧（カンマ区切り、スペースなし）
GMAIL_ACCOUNTS=personal,univ,work

# gws gmail +watch が使う GCP プロジェクト ID
GOOGLE_WORKSPACE_PROJECT_ID=

# Discord 通知先チャンネル（bot が投稿するチャンネル ID）
DISCORD_CHANNEL_ID=
DISCORD_BOT_USER_ID=

# Discord 通知 bot トークン（送信・改稿ボタン用の専用 bot）
DISCORD_NOTIFY_BOT_TOKEN=

# 通知 bot の HTTP ポート（デフォルト: 8787）
# NOTIFY_PORT=8787

# アカウント別ラベル（Discord 通知タグ用）
GMAIL_PERSONAL_LABEL=Personal
GMAIL_UNIV_LABEL=University
GMAIL_WORK_LABEL=Work

# gws 設定ディレクトリ（alias ごとのグローバル管理ディレクトリを指定）
GMAIL_PERSONAL_GWS_DIR=
GMAIL_UNIV_GWS_DIR=
GMAIL_WORK_GWS_DIR=
